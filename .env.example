# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Configuration
# Firebase Configuration (optional - for push notifications)
# These values can be found in your google-services.json or GoogleService-Info.plist
FLUTTER_FIREBASE_API_KEY=your-api-key
FLUTTER_FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FLUTTER_FIREBASE_APP_ID=your-app-id

# Market Data
TWELVE_DATA_KEY=your-twelve-data-api-key-here